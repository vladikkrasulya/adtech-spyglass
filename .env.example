# Spyglass runtime configuration.
#
# Copy this file to .env (which is git-ignored) and fill in real values for
# anything the running container actually needs. Keep .env.example up-to-date
# with EVERY variable the codebase reads, even if no value is committed.
#
# Convention: server-side env vars are SPYGLASS_* prefixed. Build-time / public
# vars use SPYGLASS_PUBLIC_* and may be embedded in client bundles.

# ── Runtime ───────────────────────────────────────────────────
# Listen port inside the container (compose maps host :8090 → container :3000).
# SPYGLASS_PORT=3000

# Filesystem path to SQLite DB inside the container. Bind-mounted from host
# /srv/DATA/AppData/adtech-spyglass/. Don't change unless you also update
# docker-compose.yml volume mapping.
# SPYGLASS_DATA_DIR=/data

# ── Phase 7 — auth (NOT IN USE YET) ───────────────────────────
# When multi-user auth lands, these become required. Keep commented until then.
#
# 32+ random bytes hex; rotate periodically. Generate with:
#   openssl rand -hex 32
# SPYGLASS_SESSION_SECRET=
#
# Bcrypt-hashed admin password (only relevant if running standalone, not behind
# the kyivtech-portal proxy which already provides auth).
# SPYGLASS_ADMIN_PASSWORD_HASH=

# ── Phase 5 — public deploy split (NOT IN USE YET) ────────────
# Build target: 'private' (auth'd workspace) or 'public' (demo, no library).
# Default: private. Public build strips the library UI at compile time.
# SPYGLASS_BUILD_TARGET=private

# ── Phase 8 — transactional email + password reset (REQUIRED in prod) ──
# Without these set, email-related features short-circuit to console-log
# (development fallback). In production set NODE_ENV=production AND fill these.
NODE_ENV=production

# Resend API key — from https://resend.com/api-keys (required in prod).
# Domain must be verified in Resend before sends will succeed (DKIM via
# Cloudflare TXT record on kyivtech.com.ua, ~5 min to propagate).
RESEND_API_KEY=

# From-address used in transactional emails. MUST be on a domain verified
# in Resend; otherwise the API rejects with 403.
EMAIL_FROM=spyglass@kyivtech.com.ua

# HMAC secret for stateless email-verify / password-reset tokens.
# Generate with: openssl rand -hex 32
# Rotating this invalidates ALL outstanding tokens (acceptable, rare).
EMAIL_TOKEN_SECRET=

# Public origin used in email links. NO trailing slash.
PUBLIC_BASE_URL=https://spyglass.kyivtech.com.ua

# ── Admin alerts via Telegram (optional) ──────────────────────
# When BOTH are set, server-side errors (email-send failures, uncaught
# exceptions, 5xx in handlers) ping the admin chat. Missing either var
# disables the channel cleanly — events still log to stderr.
# Bot token from BotFather; chat_id from /start'ing the bot then
# `curl https://api.telegram.org/bot<TOKEN>/getUpdates`.
TG_BOT_TOKEN=
TG_ADMIN_CHAT_ID=
