{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": false,
    "useUnknownInCatchVariables": false,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": false,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "//include-rationale":
    "validator.js was split into packages/core/* in Phase 1 — kept JSDoc-only typecheck across the whole backend + tests so obvious typos still surface. strict-* flags stay off until Phase 3 hand-tunes types; npm run typecheck currently passes silently as a smoke gate.",
  "include": [
    "server.js",
    "auth.js",
    "db.js",
    "email.js",
    "tokens.js",
    "packages/core/**/*.js",
    "tests/**/*.js"
  ],
  "exclude": ["node_modules", "public", "dist", "build", "coverage"]
}
