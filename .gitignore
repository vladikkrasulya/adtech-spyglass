# ── Dependencies ──────────────────────────────────────────────
node_modules/
package-lock.json.backup

# ── Environment / secrets ─────────────────────────────────────
# Never commit real env files. Only `.env.example` is tracked.
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/

# ── Data — never in repo (lives in /srv/DATA/AppData/...) ─────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/
backups/

# ── Build / dist ──────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / editor cruft ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.iml

# ── Coverage / test artifacts ─────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Misc ──────────────────────────────────────────────────────
.cache/
tmp/
temp/
