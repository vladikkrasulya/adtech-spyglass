{
  "name": "adtech-spyglass",
  "version": "0.38.1",
  "description": "OpenRTB inspector — paste a BidRequest/BidResponse, get human-readable validation, semantic crosscheck, creative preview.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --test tests/",
    "test:watch": "node --test --watch tests/",
    "test:coverage": "node --test --experimental-test-coverage tests/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@kyivtech/spyglass-core": "*",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
